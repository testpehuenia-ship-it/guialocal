// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id         String     @id @default(cuid())
  title      String     @unique
  link       String
  image      String
  businesses Business[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Business {
  id         String     @id @default(cuid())
  name       String
  image      String
  whatsapp   String
  category   Category   @relation(fields: [categoryId], references: [id])
  categoryId String
  menu       MenuItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  business    Business @relation(fields: [businessId], references: [id])
  businessId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Accommodation {
  id        String    @id @default(cuid())
  name      String
  type      String    // e.g., "Cabaña", "Hotel"
  image     String
  whatsapp  String
  features  Feature[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Feature {
  id              String        @id @default(cuid())
  name            String
  accommodation   Accommodation @relation(fields: [accommodationId], references: [id])
  accommodationId String
}

model Adventure {
  id          String   @id @default(cuid())
  name        String
  description String?
  image       String
  whatsapp    String
  category    String   // e.g., "Trekking", "Pesca"
  details     String   // Guardaremos como JSON string o separado por comas
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LocalService {
  id          String   @id @default(cuid())
  name        String
  category    String   // e.g., "Salud", "Seguridad", "Comercios"
  address     String?
  whatsapp    String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String // En producción esto debería estar hasheado
}
